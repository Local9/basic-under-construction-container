# App (optional; defaults are set in docker-compose)
# NODE_ENV=production
# PORT=3000

# Traefik routing (used by docker-compose labels)
# Hostname for the router rule when TRAEFIK_RULE is not set
DOMAIN=example.com

# Optional: override the router rule (e.g. Host(`example.com`) || PathPrefix(`/api`))
# TRAEFIK_RULE=Host(`example.com`)

# Optional: TLS certificate resolver name (e.g. letsencrypt)
TRAEFIK_CERTRESOLVER=letsencrypt

# Optional: TLS domain config (main + SANs)
# TRAEFIK_TLS_MAIN=example.com
# TRAEFIK_TLS_SANS=www.example.com,example.com
